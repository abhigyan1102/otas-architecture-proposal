[
  {
    "id": "META-001",
    "description": "Attach structured metadata with ISO identifiers to a token",
    "primitive": "IMetadataAttachable",
    "operation": "attach",
    "setup": {
      "metadata": {}
    },
    "input": {
      "caller": "0xIssuer",
      "tokenId": "0",
      "metadata": {
        "isin": "US91282CJL54",
        "lei": "254900HROIFWPRGM1V77",
        "cfi": "DBFTFR",
        "termSheetURI": "ipfs://QmExampleHash123",
        "termSheetHash": "0xabcdef1234567890",
        "extensions": ""
      }
    },
    "expected": {
      "output": {},
      "stateChanges": {
        "metadata": {
          "0": {
            "isin": "US91282CJL54",
            "lei": "254900HROIFWPRGM1V77",
            "cfi": "DBFTFR",
            "termSheetURI": "ipfs://QmExampleHash123"
          }
        }
      },
      "events": [
        { "name": "MetadataAttached", "fields": { "tokenId": "0", "isin": "US91282CJL54", "lei": "254900HROIFWPRGM1V77" } }
      ],
      "reverts": false
    }
  },
  {
