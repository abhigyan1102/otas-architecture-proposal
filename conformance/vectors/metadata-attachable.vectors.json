  {
    "id": "META-004",
    "description": "Update a specific metadata field emits MetadataUpdated event",
    "primitive": "IMetadataAttachable",
    "operation": "updateField",
    "setup": {
      "issuer": "0xIssuer",
      "metadata": {
        "0": {
          "termSheetURI": "ipfs://QmOldHash",
          "termSheetHash": "0xOLDHASH"
        }
      }
    },
    "input": {
      "caller": "0xIssuer",
      "tokenId": "0",
      "field": "termSheetURI",
      "data": "ipfs://QmNewHash456"
    },
    "expected": {
      "output": {},
      "stateChanges": {},
      "events": [
        { "name": "MetadataUpdated", "fields": { "tokenId": "0", "field": "termSheetURI", "previousHash": "0xOLDHASH" } }
      ],
      "reverts": false
    }
  }
]
