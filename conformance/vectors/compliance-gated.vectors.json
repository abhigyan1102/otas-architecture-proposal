  },
  {
    "id": "CG-006",
    "description": "Transfer rejected when amount exceeds per-transfer limit",
    "primitive": "IComplianceGated",
    "operation": "canTransfer",
    "setup": {
      "policy": "amount-limited",
      "eligibleAccounts": ["0xAlice", "0xBob"],
      "maxTransferAmount": "10000"
    },
    "input": {
      "from": "0xAlice",
      "to": "0xBob",
      "amount": "50000"
    },
    "expected": {
      "output": { "allowed": false, "reasonCode": "0x03" },
      "stateChanges": {},
      "events": [
        { "name": "TransferRestricted", "fields": { "from": "0xAlice", "to": "0xBob", "amount": "50000", "reasonCode": "0x03" } }
      ],
      "reverts": false
    },
    "note": "reasonCode 0x03 = Amount exceeds limit"
  }
]
