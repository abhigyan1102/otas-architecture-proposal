      "reverts": false
    }
  },
  {
    "id": "CG-005",
    "description": "isEligible returns false for an unregistered account",
    "primitive": "IComplianceGated",
    "operation": "isEligible",
    "setup": {
      "eligibleAccounts": ["0xAlice"]
    },
    "input": {
      "account": "0xUnknown"
    },
    "expected": {
      "output": { "eligible": false },
      "stateChanges": {},
